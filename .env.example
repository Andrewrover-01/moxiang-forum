# ──────────────────────── MySQL ────────────────────────
# Root password for the MySQL container (not used by the app directly)
MYSQL_ROOT_PASSWORD=change_me_root

# Database name (matches the schema.sql; default: moxiang_forum)
MYSQL_DATABASE=moxiang_forum

# Application-level MySQL credentials
MYSQL_USERNAME=moxiang
MYSQL_PASSWORD=change_me_password

# ──────────────────────── JWT ──────────────────────────
# IMPORTANT: replace with a long random string (32+ characters) in production!
# Example: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_RANDOM_SECRET

# ──────────────────────── Redis ────────────────────────
# Leave empty if Redis should run without a password (fine for local dev)
REDIS_PASSWORD=

# ──────────────────────── App ──────────────────────────
# Host port mapped to Nginx (frontend + reverse proxy). Default: 80
APP_PORT=80
